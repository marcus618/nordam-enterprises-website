{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/([^/]+?)/edit/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/([^/]+?)/new/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/delete/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/save/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/admin/upload/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/callback/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/api/auth/logout/?$",
			"dest": "_render"
		}
	]
}
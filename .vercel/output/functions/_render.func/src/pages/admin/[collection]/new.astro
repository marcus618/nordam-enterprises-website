---
const token = Astro.cookies.get("github_token")?.value;
if (!token) return Astro.redirect("/api/auth/login");

const { collection = "" } = Astro.params;
const isMultiImage = collection === "projects";

const singularMap: Record<string, string> = {
    products: "Product",
    projects: "Project",
    services: "Service",
};
const singular = singularMap[collection] || collection.slice(0, -1);
---

<html lang="en" data-theme="light">
    <head>
        <title>
            New {singular}
        </title>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
    </head>
    <body class="bg-gray-50 min-h-screen p-8 font-sans">
        <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8">
            <div class="bg-white p-8 rounded shadow">
                <div class="flex justify-between items-center mb-6">
                    <h1 class="text-2xl font-bold text-gray-800">
                        Create New {singular}
                    </h1>
                    <a
                        href={`/admin/${collection}`}
                        class="text-sm text-gray-500 hover:text-gray-800"
                        >Cancel</a
                    >
                </div>

                <form
                    method="POST"
                    action="/api/admin/save"
                    id={`new-${collection}-form`}
                    data-collection={collection}
                    data-is-multi={isMultiImage ? "true" : "false"}
                >
                    <input type="hidden" name="filePath" id="filePath" />
                    <input type="hidden" name="collection" value={collection} />

                    <div class="mb-4">
                        <label
                            class="block text-gray-700 text-sm font-bold mb-2"
                            >Title</label
                        >
                        <input
                            type="text"
                            name="title"
                            id="title"
                            required
                            placeholder="e.g. Generator Maintenance"
                            class="bg-white text-gray-900 shadow appearance-none border rounded w-full py-2 px-3 leading-tight focus:outline-none focus:shadow-outline"
                        />
                    </div>

                    <div class="mb-4 text-sm text-gray-500">
                        Will be saved as: <code id="filename-preview"
                            >src/content/{collection}/...</code
                        >
                    </div>

                    <div class="mb-4">
                        <label
                            class="block text-gray-700 text-sm font-bold mb-2"
                            >Sort Order</label
                        >
                        <input
                            type="number"
                            name="sortOrder"
                            value="10"
                            class="bg-white text-gray-900 shadow appearance-none border rounded w-full py-2 px-3 leading-tight focus:outline-none focus:shadow-outline"
                        />
                    </div>

                    <div class="mb-6">
                        <label
                            class="block text-gray-700 text-sm font-bold mb-2"
                            >{singular} Image(s)</label
                        >

                        {
                            isMultiImage ? (
                                <input
                                    type="hidden"
                                    name="images"
                                    id="image-input"
                                />
                            ) : (
                                <input
                                    type="hidden"
                                    name="image"
                                    id="image-input"
                                />
                            )
                        }
                        <div
                            class="border-2 border-dashed border-gray-300 rounded-lg p-6 hover:bg-gray-50 transition text-center"
                            id="drop-zone"
                        >
                            <input
                                type="file"
                                id="file-uploader"
                                accept="image/*"
                                class="hidden"
                                {...isMultiImage ? { multiple: true } : {}}
                            />
                            <label for="file-uploader" class="cursor-pointer">
                                <div class="text-blue-600 font-semibold">
                                    Click to upload
                                </div>
                                <p class="text-xs text-gray-500">
                                    or drag and drop an image here
                                </p>
                            </label>
                        </div>

                        <div
                            id="preview-grid"
                            class="grid grid-cols-3 gap-4 mt-4"
                        >
                        </div>

                        <p
                            id="upload-status"
                            class="text-xs text-gray-500 mt-2 h-4"
                        >
                        </p>
                    </div>

                    <script>
                        const fileInput =
                            document.getElementById("file-uploader");
                        const hiddenInput =
                            document.getElementById("image-input");
                        const previewGrid =
                            document.getElementById("preview-grid");
                        const form = document.querySelector("form");

                        // Read the variables we passed to the HTML
                        if (!form) throw new Error("Form not found");
                        const collectionName =
                            form.getAttribute("data-collection");
                        const isMulti =
                            form.getAttribute("data-is-multi") === "true";

                        // Unify state to always use an array
                        let filesToUpload: File[] = [];
                        function updateUI() {
                            if (previewGrid) {
                                previewGrid.innerHTML = "";
                            }

                            filesToUpload.forEach((fileObj, index) => {
                                const localUrl = URL.createObjectURL(fileObj);
                                renderThumbnail(localUrl, () => {
                                    filesToUpload.splice(index, 1);
                                    updateUI();
                                });
                            });

                            if (
                                typeof (window as any).syncPreviewImage ===
                                "function"
                            ) {
                                (window as any).syncPreviewImage(
                                    filesToUpload,
                                    [],
                                );
                            }
                        }

                        function renderThumbnail(
                            url: string,
                            onRemove: () => void,
                        ) {
                            const div = document.createElement("div");
                            div.className =
                                "relative group aspect-square bg-gray-100 rounded border overflow-hidden";
                            div.innerHTML = `<img src="${url}" class="w-full h-full object-cover" />
            <button type="button" class="absolute top-1 right-1 bg-red-600 text-white rounded-full w-6 h-6 flex items-center justify-center text-xs shadow">✕</button>
        `;
                            const btn = div.querySelector("button");
                            if (btn) {
                                btn.onclick = onRemove;
                                if (previewGrid) {
                                    previewGrid.appendChild(div);
                                }
                            }
                        }

                        if (!fileInput || !hiddenInput) {
                            throw new Error(
                                "Required input elements not found",
                            );
                        }
                        fileInput.addEventListener("change", (e) => {
                            const target = e.target as HTMLInputElement | null;
                            if (!target || !target.files) return;

                            const files = Array.from(target.files);

                            // Single vs Multi Logic!
                            if (isMulti) {
                                filesToUpload = [...filesToUpload, ...files];
                            } else {
                                filesToUpload = [files[0]]; // Overwrite with only the newest file
                            }

                            updateUI();
                            (fileInput as HTMLInputElement).value = "";
                        });

                        form.addEventListener("submit", async (e) => {
                            e.preventDefault();
                            console.info("--- STARTING FORM SUBMISSION ---");
                            console.info(
                                `Collection: ${collectionName}, IsMulti: ${isMulti}`,
                            );

                            if (filesToUpload.length === 0) {
                                console.warn(
                                    "Upload aborted: No files selected.",
                                );
                                alert(
                                    `Please upload at least one image for this ${collectionName}.`,
                                );
                                return;
                            }

                            const submitBtn = form.querySelector(
                                'button[type="submit"]',
                            );
                            if (submitBtn) {
                                (submitBtn as HTMLButtonElement).textContent =
                                    "Uploading...";
                                (submitBtn as HTMLButtonElement).disabled =
                                    true;
                            }

                            try {
                                const uploadedUrls = [];
                                console.info(
                                    `Starting upload loop for ${filesToUpload.length} file(s).`,
                                );

                                for (let i = 0; i < filesToUpload.length; i++) {
                                    const file = filesToUpload[i];
                                    console.info(
                                        `[File ${i + 1}/${filesToUpload.length}] Preparing: '${file.name}' (${(file.size / 1024).toFixed(2)} KB)`,
                                    );

                                    const formData = new FormData();
                                    formData.append("file", file);

                                    console.info(
                                        `[File ${i + 1}] Executing fetch to /api/admin/upload...`,
                                    );

                                    const fetchStartTime = Date.now();
                                    const res = await fetch(
                                        "/api/admin/upload",
                                        {
                                            method: "POST",
                                            body: formData,
                                        },
                                    );
                                    const fetchDuration =
                                        Date.now() - fetchStartTime;

                                    console.info(
                                        `[File ${i + 1}] Fetch completed in ${fetchDuration}ms. Status: ${res.status} ${res.statusText}`,
                                    );

                                    const rawText = await res.text();
                                    console.info(
                                        `[File ${i + 1}] Raw server response (first 100 chars): ${rawText.substring(0, 100)}`,
                                    );

                                    let data;
                                    try {
                                        data = JSON.parse(rawText);
                                        console.info(
                                            `[File ${i + 1}] JSON parsed successfully. Success: ${data.success}`,
                                        );
                                    } catch (jsonErr) {
                                        console.error(
                                            `[File ${i + 1}] CRITICAL ERROR: Server did not return valid JSON. Are you hitting a hard timeout or gateway error?`,
                                        );
                                        throw new Error(
                                            "Server returned an invalid non-JSON response.",
                                        );
                                    }

                                    if (data.success) {
                                        uploadedUrls.push(data.url);
                                        console.info(
                                            `[File ${i + 1}] Saved to URL: ${data.url}`,
                                        );
                                    } else {
                                        throw new Error(
                                            `Upload failed on server: ${data.error || "No error message provided"}`,
                                        );
                                    }
                                }

                                console.info(
                                    "--- ALL FILES UPLOADED SUCCESSFULLY ---",
                                );

                                if (isMulti) {
                                    const multiVal = uploadedUrls.join(", ");
                                    (hiddenInput as HTMLInputElement).value =
                                        multiVal;
                                    console.info(
                                        `Set multi-image hidden field to: ${multiVal}`,
                                    );
                                } else {
                                    const singleVal = uploadedUrls[0] || "";
                                    (hiddenInput as HTMLInputElement).value =
                                        singleVal;
                                    console.info(
                                        `Set single-image hidden field to: ${singleVal}`,
                                    );
                                }

                                if (!(hiddenInput as HTMLInputElement).value) {
                                    throw new Error(
                                        "Missing Upload URL in hidden field.",
                                    );
                                }

                                console.info(
                                    "Submitting form natively to /api/admin/save...",
                                );
                                form.submit();
                            } catch (err: any) {
                                console.error("--- UPLOAD PROCESS FAILED ---");
                                console.error(`Error Message: ${err.message}`);
                                if (err.stack)
                                    console.error(`Stack Trace:`, err.stack);

                                if (submitBtn) {
                                    (
                                        submitBtn as HTMLButtonElement
                                    ).textContent = "Upload Failed";
                                    (submitBtn as HTMLButtonElement).disabled =
                                        false;
                                }
                                alert(
                                    "The upload failed. Please check the browser console logs and send them to the developer.",
                                );
                            }
                        });
                    </script>

                    <div class="mb-6">
                        <label
                            class="block text-gray-700 text-sm font-bold mb-2"
                            >Description</label
                        >
                        <textarea
                            id="body-input"
                            name="body"
                            rows="10"
                            class="bg-white text-gray-900 shadow appearance-none border rounded w-full py-2 px-3 leading-tight focus:outline-none focus:shadow-outline font-mono"
                        ></textarea>
                    </div>

                    <button
                        type="submit"
                        class="bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline"
                    >
                        Create {singular}
                    </button>
                </form>
            </div>

            <div
                class="bg-gray-100 p-8 rounded shadow self-start sticky top-8 border border-gray-200"
            >
                <h2 class="text-xl font-bold text-gray-800 mb-6 border-b pb-2">
                    Live Preview
                </h2>
                <div id="preview-container" class="flex justify-center">
                    {
                        isMultiImage ? (
                            <div class="w-full max-w-2xl">
                                <div
                                    class="card bg-base-100 shadow-xl flex flex-col hidden"
                                    id="preview-project"
                                >
                                    <div
                                        id="carousel-preview"
                                        class="carousel w-full rounded-t-box h-80 scroll-smooth"
                                    >
                                        <div class="carousel-item relative w-full bg-gray-200 flex items-center justify-center">
                                            <span class="text-gray-400">
                                                No images
                                            </span>
                                        </div>
                                    </div>
                                    <div class="card-body flex flex-col">
                                        <h2
                                            class="card-title"
                                            id="preview-project-title"
                                        >
                                            Title
                                        </h2>
                                        <div
                                            class="text-base-content/80 text-sm flex-grow prose prose-sm max-w-none"
                                            id="preview-project-body"
                                        />
                                    </div>
                                </div>
                            </div>
                        ) : (
                            <div class="w-full max-w-[400px]">
                                <div
                                    class="card bg-base-100 shadow-xl flex flex-col hidden"
                                    id="preview-content"
                                >
                                    <figure>
                                        <img
                                            id="preview-content-image"
                                            src="/images/placeholder.png"
                                            alt="Preview Image"
                                            class="w-full h-56 object-cover"
                                        />
                                    </figure>
                                    <div class="card-body flex flex-col">
                                        <h2
                                            class="card-title"
                                            id="preview-content-title"
                                        >
                                            Title
                                        </h2>
                                        <div
                                            class="text-base-content/80 text-sm flex-grow prose prose-sm max-w-none"
                                            id="preview-content-body"
                                        />
                                        <div class="card-actions justify-start pt-4">
                                            <a
                                                href="#"
                                                class="btn btn-neutral w-full"
                                            >
                                                Contact us and Request a Quote
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        )
                    }
                </div>
            </div>

            <!-- Add marked.js for live markdown parsing in preview -->
            <script
                is:inline
                src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"
            ></script>

            <script>
                // Live preview logic
                const titleInput = document.getElementById(
                    "title",
                ) as HTMLInputElement;
                const bodyInput = document.getElementById(
                    "body-input",
                ) as HTMLTextAreaElement;
                const collection =
                    document
                        .querySelector("form")
                        ?.getAttribute("data-collection") || "";
                const isMulti =
                    document
                        .querySelector("form")
                        ?.getAttribute("data-is-multi") === "true";

                const previewProject =
                    document.getElementById("preview-project");
                const previewContent =
                    document.getElementById("preview-content");

                const previewProjectTitle = document.getElementById(
                    "preview-project-title",
                );
                const previewProjectBody = document.getElementById(
                    "preview-project-body",
                );
                const carouselPreview =
                    document.getElementById("carousel-preview");

                const previewContentImage = document.getElementById(
                    "preview-content-image",
                ) as HTMLImageElement;
                const previewContentTitle = document.getElementById(
                    "preview-content-title",
                );
                const previewContentBody = document.getElementById(
                    "preview-content-body",
                );

                function updatePreviewText() {
                    const titleText = titleInput?.value || "Title";
                    const bodyText = marked.parse(
                        bodyInput?.value || "Description",
                    );

                    if (isMulti && previewProject) {
                        previewProject.classList.remove("hidden");
                        if (previewProjectTitle)
                            previewProjectTitle.textContent = titleText;
                        if (previewProjectBody)
                            previewProjectBody.innerHTML = bodyText;
                    } else if (!isMulti && previewContent) {
                        previewContent.classList.remove("hidden");
                        if (previewContentTitle)
                            previewContentTitle.textContent = titleText;
                        if (previewContentBody)
                            previewContentBody.innerHTML = bodyText;
                    }
                }

                // Sync images with preview
                (window as any).syncPreviewImage = function (
                    filesToUpload: File[],
                    existingUrls: string[],
                ) {
                    const finalUrls: string[] = [];
                    existingUrls.forEach((url) => finalUrls.push(url));
                    filesToUpload.forEach((f) =>
                        finalUrls.push(URL.createObjectURL(f)),
                    );

                    if (isMulti && carouselPreview) {
                        carouselPreview.innerHTML = "";
                        if (finalUrls.length === 0) {
                            carouselPreview.innerHTML = `
                            <div class="carousel-item relative w-full bg-gray-200 flex items-center justify-center">
                                <span class="text-gray-400">No images</span>
                            </div>
                        `;
                        } else {
                            finalUrls.forEach((url, i) => {
                                carouselPreview.innerHTML += `
                                <div id="carousel-preview-slide${i}" class="carousel-item relative w-full">
                                    <img src="${url}" class="w-full object-cover" />
                                    <div class="absolute flex justify-between transform -translate-y-1/2 left-5 right-5 top-1/2">
                                        <a href="#carousel-preview-slide${(i - 1 + finalUrls.length) % finalUrls.length}" class="btn btn-circle btn-sm" onclick="event.preventDefault(); document.getElementById('carousel-preview-slide${(i - 1 + finalUrls.length) % finalUrls.length}').scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });">❮</a> 
                                        <a href="#carousel-preview-slide${(i + 1) % finalUrls.length}" class="btn btn-circle btn-sm" onclick="event.preventDefault(); document.getElementById('carousel-preview-slide${(i + 1) % finalUrls.length}').scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'start' });">❯</a>
                                    </div>
                                </div>
                            `; 
                            });
                        }
                    } else if (!isMulti && previewContentImage) {
                        if (finalUrls.length > 0) {
                            previewContentImage.src = finalUrls[0];
                        } else {
                            previewContentImage.src = "/images/placeholder.png";
                        }
                    }
                };

                if (titleInput)
                    titleInput.addEventListener("input", updatePreviewText);
                if (bodyInput)
                    bodyInput.addEventListener("input", updatePreviewText);

                // Initial render
                window.addEventListener("DOMContentLoaded", updatePreviewText);
                updatePreviewText();
            </script>
        </div>

        <script>
            // Auto-generate the filename from the title
            const fileInputPath = document.getElementById("filePath");
            const preview = document.getElementById("filename-preview");

            const formElement = document.querySelector("form");
            const activeCollection = formElement
                ? formElement.getAttribute("data-collection")
                : "unknown";

            const titleInputEl = document.getElementById("title");
            if (titleInputEl && fileInputPath && preview) {
                titleInputEl.addEventListener("input", (e) => {
                    const slug = (e.target as HTMLInputElement).value
                        .toLowerCase()
                        .replace(/[^a-z0-9]+/g, "-")
                        .replace(/(^-|-$)+/g, "");
                    const path = `src/content/${activeCollection}/${slug}.md`;
                    (fileInputPath as HTMLInputElement).value = path;
                    (preview as HTMLSpanElement).textContent = path;
                });
            }
        </script>
    </body>
</html>

---
const navItems = [
  { href: "/", label: "Home" },
  { href: "/products", label: "Products" },
  { href: "/services", label: "Services" },
  { href: "/about", label: "About" },
];
---
<div class="w-full bg-white sticky top-0 z-40 border-b border-gray-100">
  <div class="navbar max-w-[1400px] mx-auto px-6 md:px-12 py-3">
    <div class="navbar-start">
      <a href="/" class="flex items-center">
        <img src="/images/logo.jpg" alt="Nordam Enterprises" class="h-10 md:h-12" />
      </a>
    </div>

    <div class="navbar-center hidden lg:flex">
      <ul class="menu menu-horizontal px-1 gap-6">
        {navItems.map(item => (
          <li>
            <a href={item.href} class="text-xs font-bold tracking-[0.2em] text-gray-500 hover:text-black uppercase bg-transparent hover:bg-transparent">
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="navbar-end gap-2">
      <a href="mailto:nordam@africa-online.net?subject=Inquiry" class="hidden lg:flex btn btn-outline border-gray-300 btn-sm rounded-full text-xs font-bold tracking-widest uppercase hover:bg-black hover:border-black hover:text-white transition-all">
        Get in touch
      </a>
      
      <div class="lg:hidden">
        <button class="btn btn-square btn-ghost" onclick="mobile_menu_modal.showModal()">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-6 h-6 stroke-current text-black"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
        </button>
      </div>
    </div>
  </div>
</div>
---
export const prerender = true;
import Layout from "../layouts/Layout.astro";
const pageDescription =
  "Your trusted partner for innovative and reliable power solutions in Malawi. We provide high-performance diesel generators, advanced solar systems, and expert support.";
---

<Layout title="Nordam Enterprises | Home" description={pageDescription}>
  <div class="min-h-[calc(100vh-80px)] bg-base-100 flex flex-col justify-center overflow-hidden">
    <div class="container mx-auto px-4 md:px-8 py-12 md:py-24">
      
      <div class="flex flex-col lg:flex-row items-center justify-between gap-12 lg:gap-8 xl:gap-12">
        
        <div class="lg:w-[50%] xl:w-[45%] flex flex-col items-start text-left z-10">
          <p class="text-sm md:text-base text-base-content/60 uppercase tracking-widest mb-4 font-semibold">
            Innovative and reliable
          </p>

          <h1 class="text-6xl sm:text-7xl lg:text-8xl font-extrabold text-base-content leading-[1.1] mb-6 tracking-tight">
            Power <br />
            <span class="text-yellow-500">Solutions</span>
          </h1>

          <p class="text-base md:text-lg text-base-content/80 max-w-md mb-10 leading-relaxed">
            In the warm heart of Africa. Your trusted partner for
            high-performance diesel generators, advanced solar systems, and
            expert support in Malawi since 1993.
          </p>

          <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
            <a href="/products" class="btn btn-neutral w-full sm:w-auto px-8 rounded-lg">
              Explore Products
            </a>
            <a href="/services" class="btn btn-outline border-base-content/20 w-full sm:w-auto px-8 rounded-lg">
              Our Services
            </a>
          </div>
        </div>

        <div class="lg:w-[50%] xl:w-[55%] w-full flex justify-center lg:justify-end mt-12 lg:mt-0">
          <div class="flex gap-3 sm:gap-4 items-center w-full lg:w-auto justify-center">
            
            <div class="w-[55%] sm:w-48 md:w-64 h-[18rem] sm:h-[24rem] md:h-[32rem] overflow-hidden bg-base-200 rounded-2xl shadow-xl shrink-0">
              <img
                src="/images/hero/hero-background4.jpg"
                alt="Nordam Main Power Solution"
                class="w-full h-full object-cover hover:grayscale transition duration-700"
              />
            </div>

            <div class="w-[40%] sm:w-auto flex flex-col gap-3 sm:gap-4 shrink-0">
              <div class="sm:w-32 md:w-48 h-[8.5rem] sm:h-44 md:h-[15.5rem] overflow-hidden bg-base-200 rounded-2xl shadow-xl">
                <img
                  src="/images/hero/hero-background2.jpg"
                  alt="Generators"
                  class="w-full h-full object-cover object-[25%_center] hover:grayscale transition duration-700"
                />
              </div>
              <div class="sm:w-32 md:w-48 h-[8.5rem] sm:h-44 md:h-[15.5rem] overflow-hidden bg-base-200 rounded-2xl shadow-xl">
                <img
                  src="/images/hero/hero-background3.jpg"
                  alt="Solar Panels"
                  class="w-full h-full object-cover hover:grayscale transition duration-700"
                />
              </div>
            </div>

            <div class="hidden xl:block w-48 h-[26rem] overflow-hidden bg-base-200 rounded-2xl shadow-xl shrink-0">
              <img
                src="/images/hero/hero-background.jpg"
                alt="Additional Services"
                class="w-full h-full object-cover hover:grayscale transition duration-700"
              />
            </div>
            
          </div>
        </div>
        
      </div>
    </div>
  </div>
</Layout>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Nordam Enterprises",
    "address": {
      "streetAddress": "Area 28, Plot 130",
      "addressLocality": "Lilongwe",
      "addressCountry": "Malawi"
    },
    "telephone": "+265 999 246 782",
    "email": "nordam@africa-online.net",
    "url": "https://www.nordamenterprises.com",
    "description": "Generators, solar panels, inverters, and power solutions in Lilongwe, Malawi."
  }
</script>